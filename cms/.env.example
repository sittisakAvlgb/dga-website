# ===== DGA CMS (Strapi) — ตัวอย่างไฟล์ตั้งค่า =====
# คัดลอกเป็น .env แล้วเติมค่าจริง (อย่า commit .env ขึ้น Git)
# สร้างค่าสุ่ม (salt/keys) ด้วย:  node -e "console.log(require('crypto').randomBytes(16).toString('base64'))"

HOST=0.0.0.0
PORT=1337

# คีย์ความปลอดภัย (ใส่ค่าสุ่มของจริง)
APP_KEYS=key1==,key2==,key3==,key4==
API_TOKEN_SALT=changeme==
ADMIN_JWT_SECRET=changeme==
TRANSFER_TOKEN_SALT=changeme==
JWT_SECRET=changeme==

# ฐานข้อมูล — dev ใช้ sqlite ได้เลย, production แนะนำ postgres
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db
# --- production (postgres) ---
# DATABASE_CLIENT=postgres
# DATABASE_URL=postgres://user:pass@host:5432/dga_cms
# DATABASE_SSL=true

# โดเมนหน้าบ้านที่อนุญาตให้เรียก API (คั่นด้วย comma)
CORS_ORIGINS=http://localhost:8123,http://127.0.0.1:5500,https://www.dga.or.th
