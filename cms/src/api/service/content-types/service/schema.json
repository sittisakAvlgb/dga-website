{
  "kind": "collectionType",
  "collectionName": "services",
  "info": {
    "singularName": "service",
    "pluralName": "services",
    "displayName": "บริการ (Service)",
    "description": "บริการดิจิทัลภาครัฐ แยกตามกลุ่มผู้ใช้งาน"
  },
  "options": { "draftAndPublish": true },
  "pluginOptions": { "i18n": { "localized": true } },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "subtitle": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "description": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "group": {
      "type": "enumeration",
      "enum": ["citizen", "gov", "biz"],
      "default": "citizen",
      "required": true,
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "icon": {
      "type": "string",
      "default": "i-grid",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "url": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "linkLabel": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "tag": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "order": {
      "type": "integer",
      "default": 0,
      "pluginOptions": { "i18n": { "localized": false } }
    }
  }
}
